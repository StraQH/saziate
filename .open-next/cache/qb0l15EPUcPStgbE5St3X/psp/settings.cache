abel\">Contact Email</label><input type=\"email\" class=\"input\" disabled=\"\" value=\"ops@lekkigreenclean.com\"/></div><div class=\"form-group\"><label class=\"label\">Contact Phone</label><input type=\"tel\" class=\"input\" disabled=\"\" value=\"+2348021234567\"/></div></div><div class=\"form-group\"><label class=\"label\">Office Address</label><input type=\"text\" class=\"input\" disabled=\"\" value=\"Plot 15, Admiralty Way, Lekki\"/></div></form></div><div class=\"card\"><div style=\"display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-credit-card\" aria-hidden=\"true\" style=\"color:var(--color-primary)\"><rect width=\"20\" height=\"14\" x=\"2\" y=\"5\" rx=\"2\"></rect><line x1=\"2\" x2=\"22\" y1=\"10\" y2=\"10\"></line></svg><h2 style=\"font-size:1.25rem;font-weight:600\">Provisioned DVA</h2></div><p class=\"text-muted text-sm\" style=\"margin-bottom:1.5rem\">Your Paystack Dedicated Virtual Account. Residents transfer payments directly to this account for automated reconciliation.</p><div style=\"background:var(--color-bg);padding:1rem 1.25rem;border-radius:var(--radius-md);display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:1.5rem\"><div><p class=\"text-xs text-muted\">Bank Name</p><p class=\"font-semibold\" style=\"font-size:1rem;margin-top:0.15rem\">Wema Bank</p></div><div><p class=\"text-xs text-muted\">Account Number</p><p class=\"font-semibold\" style=\"font-size:1rem;margin-top:0.15rem;font-family:monospace\">9920192834</p></div><div><p class=\"text-xs text-muted\">Account Name</p><p class=\"font-semibold\" style=\"font-size:1.025rem;margin-top:0.15rem\">Saziate - Lekki Green Cleaners Ltd</p></div></div></div><div class=\"card\"><h2 style=\"font-size:1.25rem;font-weight:600;margin-bottom:0.5rem\">Se